# Loop RevOps Agents — environment template
# Copy to .env and fill in. Never commit .env.

# --- Runtime paths (auto-detected by bootstrap.sh; override if needed) ---
REVOPS_REPO_ROOT=/Users/ottimate/loop-revops-agents
REVOPS_DB_URL=sqlite:///${REVOPS_REPO_ROOT}/shared/db/loop_revops.db
REVOPS_LOG_DIR=${REVOPS_REPO_ROOT}/var/log
REVOPS_KNOWLEDGE_BACKEND=chromadb_local
REVOPS_SECRETS_BACKEND=dotenv
# REVOPS_SECRETS_BACKEND=gcp_secret_manager  # Phase 4

# --- Salesforce (sf CLI auth; service identity) ---
# Reads via SF_ORG_ALIAS; writes via SF_WRITE_ORG_ALIAS (revops-agent service user);
# schema rehearsals via SF_SANDBOX_ORG_ALIAS (Developer Sandbox, daily refresh).
SF_SERVICE_USER=salesops@tryloop.ai
SF_ORG_ALIAS=salesops
SF_WRITE_ORG_ALIAS=revops-agent-prod
SF_SANDBOX_ORG_ALIAS=salesops-sandbox

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-REPLACE
SLACK_APP_TOKEN=xapp-REPLACE
SLACK_TEST_CHANNEL=U07P4GX9YLQ
SLACK_DEV_GUARD=1

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=sk-ant-REPLACE

# --- Integrations ---
FIREFLIES_API_KEY=REPLACE
CLAY_API_KEY=REPLACE
APOLLO_API_KEY=REPLACE
VITALLY_API_KEY=REPLACE

# --- Top of Funnel (Agent 1) ---
# Monthly Clay credit ceiling — enrichment pipeline blocks new runs above this.
CLAY_MONTHLY_BUDGET_CREDITS=50000
# SObject used by Nooks cadence enrollment writes. Confirm at D1 kickoff with O.
NOOKS_CADENCE_SF_OBJECT=CampaignMember

# --- CS agent (Phase 1 — Agent 4) ---
# When set, weekly CS digest DMs Jackie in addition to #agent-cs-log. Leave as
# REPLACE to route only to the channel.
JACKIE_SLACK_USER_ID=REPLACE
# Channel used for Mark Churned + churn outreach + CSM reassignment approvals.
CS_JACKIE_CHANNEL=#agent-cs-log

# --- GCP (Phase 4) ---
# GCP_PROJECT=loop-revops-agents
